# Copy to .env.local and adjust. Do not commit .env or .env.local.
# See src/config/index.ts for all keys.
# Next.js requires the NEXT_PUBLIC_ prefix for client-exposed env vars.

NEXT_PUBLIC_APP_NAME=NextjsBoilerplate
NEXT_PUBLIC_ENVIRONMENT=development

# API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_TIMEOUT=30000

# Sentry (leave unset to disable)
# NEXT_PUBLIC_SENTRY_DSN=https://key@org.ingest.sentry.io/project
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
